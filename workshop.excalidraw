    {
      "id": "3AfqwcF9k8HcIvzhMe6wC",
      "type": "text",
      "x": 125.15587995219266,
      "y": 27169.472719500205,
      "width": 2495.658304567571,
      "height": 282.0047572039175,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bEU",
      "roundness": null,
      "seed": 750921225,
      "version": 211,
      "versionNonce": 1421157257,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1781854752776,
      "link": null,
      "locked": false,
      "text": "The system prompt is a separate, privileged system field that sets standing persona, rules, and constraints which the\nmodel weights more heavily and holds steady across all turns (also making it the natural prompt-caching anchor and the\nright place for guardrails), whereas the first user prompt is just one message in the conversation history that gets diluted\nas the dialogue grows; so while you can define character there, the system prompt is the better home for anything beyond\na one-shot interaction.",
      "fontSize": 45.1207611526268,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The system prompt is a separate, privileged system field that sets standing persona, rules, and constraints which the model weights more heavily and holds steady across all turns (also making it the natural prompt-caching anchor and the right place for guardrails), whereas the first user prompt is just one message in the conversation history that gets diluted as the dialogue grows; so while you can define character there, the system prompt is the better home for anything beyond a one-shot interaction.",
      "autoResize": false,
      "lineHeight": 1.25
    },
