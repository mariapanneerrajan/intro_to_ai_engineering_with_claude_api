      "boundElements": [],
      "updated": 1781847150389,
      "link": null,
      "locked": false,
      "text": "Based on semantics,\neach word could have multiple meanings.\n\nExample,\nClaude:\n\n1. Claude can write code, answer questions, and analyze documents.\n2. We stopped for lunch in Claude, Texas, on the drive to Amarillo.\n3. Landscape painters once used a Claude glass to frame and tint their views.",
      "fontSize": 52.0000697544652,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Based on semantics,\neach word could have multiple meanings.\n\nExample,\nClaude:\n\n1. Claude can write code, answer questions, and analyze documents.\n2. We stopped for lunch in Claude, Texas, on the drive to Amarillo.\n3. Landscape painters once used a Claude glass to frame and tint their views.",
      "autoResize": true,
      "lineHeight": 1.25
    },
